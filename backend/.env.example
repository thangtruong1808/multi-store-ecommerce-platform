# Copy to ".env" next to this file (backend/.env). The API loads backend/.env — not the frontend folder.

ASPNETCORE_ENVIRONMENT=
ASPNETCORE_URLS=
CORS_ALLOWED_ORIGINS=
ConnectionStrings__Default=
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_TOKEN_MINUTES=
JWT_REFRESH_TOKEN_DAYS=
AUTH_COOKIE_SECURE=

# -----------------------------------------------------------------------------
# Storefront checkout (Stripe Hosted Checkout)
# -----------------------------------------------------------------------------
# Required for Stripe redirect URLs unless you rely on fallbacks (see below).
# Must match the URL users see in the browser for the SPA (scheme + host + port). No trailing slash.
# Example local Vite: http://localhost:5173
PUBLIC_APP_BASE_URL=http://localhost:5173

# Unused — checkout fulfilment store is chosen on the cart page (API: POST /api/checkout/eligible-stores).
# CHECKOUT_DEFAULT_STORE_ID=

# -----------------------------------------------------------------------------
# Stripe (test mode — Dashboard: https://dashboard.stripe.com/test/apikeys )
# -----------------------------------------------------------------------------
# Required for creating Checkout Sessions and verifying webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — reserved for future Stripe.js / Payment Element in the browser (hosted Checkout does not need this on the API).
STRIPE_PUBLISHABLE_KEY=

# Not read by the API yet (checkout currency is AUD in code). Set if you extend Stripe options later.
# STRIPE_CURRENCY=aud

# Stripe Connect / Express account id — not read by the API currently.
# STRIPE_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Azure Blob Storage — product photos
# -----------------------------------------------------------------------------
AZURE_STORAGE_ENABLED=true
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=product-photos
AZURE_STORAGE_PUBLIC_BASE_URL=
# Optional max incoming upload bytes (default 8388608 = 8MB)
AZURE_STORAGE_MAX_UPLOAD_BYTES=8388608

# -----------------------------------------------------------------------------
# Azure Communication Services — transactional email (password reset, contact form)
# -----------------------------------------------------------------------------
ACS_EMAIL_ENABLED=false
ACS_EMAIL_CONNECTION_STRING=
ACS_EMAIL_SENDER_ADDRESS=DoNotReply@example.com
PASSWORD_RESET_TOKEN_MINUTES=30
# Your inbox — contact form messages are sent here (same ACS resource as above)
CONTACT_FORM_TO_EMAIL=
