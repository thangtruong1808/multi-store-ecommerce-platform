# Copy this file to `.env.local` (or `.env`) and set your values.
# Do not commit real email addresses to git — use placeholders here only.

# API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:5080

# Public base URL for product photos (Azure blob or CDN). No trailing slash.
VITE_PRODUCT_MEDIA_BASE_URL=

# Support inbox shown in the home page footer (mailto link). Match backend CONTACT_FORM_TO_EMAIL.
VITE_SUPPORT_EMAIL=
