VITE_API_BASE_URL=

# Public base URL for product photos (Azure blob or CDN). No trailing slash.
# Optional if the dashboard loads GET /api/products/media/config instead.
VITE_PRODUCT_MEDIA_BASE_URL=

# Optional — only needed if you add Stripe.js / Payment Element later (hosted Checkout redirect does not require this).
VITE_STRIPE_PUBLISHABLE_KEY=

# Checkout redirect URLs use PUBLIC_APP_BASE_URL on the BACKEND (frontend/.env does not apply).
# Set PUBLIC_APP_BASE_URL in backend/.env (same origin as this dev server, e.g. http://localhost:5173).

# Support inbox for home page footer mailto link (no real address in repo — set in your local .env only).
# Should match backend CONTACT_FORM_TO_EMAIL.
VITE_SUPPORT_EMAIL=
