VITE_API_BASE_URL=

# Optional — only needed if you add Stripe.js / Payment Element later (hosted Checkout redirect does not require this).
VITE_STRIPE_PUBLISHABLE_KEY=

# Checkout redirect URLs use PUBLIC_APP_BASE_URL on the BACKEND (frontend/.env does not apply).
# Set PUBLIC_APP_BASE_URL in backend/.env (same origin as this dev server, e.g. http://localhost:5173).
