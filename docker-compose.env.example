# Copy to ".env" in the repo root (same folder as docker-compose.yml).
# Used by docker compose for postgres + api services.

# -----------------------------------------------------------------------------
# PostgreSQL (compose service: postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=MULTIPLY

# -----------------------------------------------------------------------------
# API — maps to ASP.NET Core configuration (compose service: api)
# See also backend/.env.example for full descriptions.
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
CORS_ALLOWED_ORIGINS=http://localhost
PUBLIC_APP_BASE_URL=http://localhost
MAINTENANCE_MODE=false

JWT_SECRET=change-me-use-a-long-random-secret-at-least-32-chars
JWT_ISSUER=multi-store-ecommerce-platform-api
JWT_AUDIENCE=multi-store-ecommerce-platform-client
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_COOKIE_SECURE=false

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

AZURE_STORAGE_ENABLED=false
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=product-photos
AZURE_STORAGE_PUBLIC_BASE_URL=
AZURE_STORAGE_MAX_UPLOAD_BYTES=8388608

ACS_EMAIL_ENABLED=false
ACS_EMAIL_CONNECTION_STRING=
ACS_EMAIL_SENDER_ADDRESS=DoNotReply@example.com
PASSWORD_RESET_TOKEN_MINUTES=30
CONTACT_FORM_TO_EMAIL=

# -----------------------------------------------------------------------------
# Frontend image build (compose service: web) — optional overrides
# Leave VITE_API_BASE_URL empty to use same-origin /api via nginx proxy.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=
VITE_PRODUCT_MEDIA_BASE_URL=
VITE_SUPPORT_EMAIL=
